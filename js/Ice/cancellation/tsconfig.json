{
    "compilerOptions": {
        "lib": ["esnext"],
        "target": "es2020",
        "module": "es2022", // "es2022" required for top-level 'await using' statements
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "noEmit": true,
        "strict": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": ["*.ts"]
}
